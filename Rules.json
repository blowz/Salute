{
  "version": "1.0.4",
  "rules": [
    {
      "id": "sbxh_webtoon",
      "name": "SBXH 웹툰",
      "urlPattern": ".*sbxh[0-9]*\\..*/webtoon/.*",
      "category": "Webtoon",
      "meta": {
        "title": "h1.hero-v2-title",
        "author": "div.hero-v2-author",
        "thumb": {
          "selector": "div.hero-v2-thumb img",
          "attr": "src"
        },
        "status": "span.pill-status",
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.ep-list-v2",
        "item": "li.ep-row-v2",
        "num": "span.ep-row-v2-no",
        "title": ".ep-row-v2-title strong",
        "link": {
          "selector": "a.ep-row-v2-link",
          "attr": "href"
        },
        "date": "span.ep-row-v2-date"
      },
      "viewer": {
        "fetchMethod": "iframe",
        "remove": [".a28415453-br", "[aria-label='배너 광고']"],
        "imageContainer": "div.vw-imgs",
        "imageItem": "img:not(.a28415453-br img, button img)",
        "lazyAttrOptions": [
          "data-src",
          "data-lazy",
          "src"
        ]
      }
    },
    {
      "id": "sbxh_manhwa",
      "name": "SBXH 만화",
      "urlPattern": ".*sbxh[0-9]*\\..*/manhwa/.*",
      "category": "Manga",
      "meta": {
        "title": "h1.hero-v2-title",
        "author": "div.hero-v2-author",
        "thumb": {
          "selector": "div.hero-v2-thumb img",
          "attr": "src"
        },
        "status": "span.pill-status",
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.ep-list-v2",
        "item": "li.ep-row-v2",
        "num": "span.ep-row-v2-no",
        "title": ".ep-row-v2-title strong",
        "link": {
          "selector": "a.ep-row-v2-link",
          "attr": "href"
        },
        "date": "span.ep-row-v2-date"
      },
      "viewer": {
        "fetchMethod": "iframe",
        "remove": [".a28415453-br", "[aria-label='배너 광고']"],
        "imageContainer": "div.vw-imgs",
        "imageItem": "img:not(.a28415453-br img, button img)",
        "lazyAttrOptions": [
          "data-src",
          "data-lazy",
          "src"
        ]
      }
    },
    {
      "id": "sbxh_novel",
      "name": "SBXH 소설",
      "urlPattern": ".*sbxh[0-9]*\\..*/novel/.*",
      "category": "Novel",
      "meta": {
        "title": "div.nd-info h1",
        "author": "div.nd-meta span:first-child",
        "thumb": {
          "selector": "div.nd-thumb img",
          "attr": "src"
        },
        "status": "span.nv-badge",
        "tags": "div.hero-v2-tags"
      },
      "list": {
        "container": "ul.novel-eps",
        "item": "li",
        "num": "span.ne-num",
        "title": "span.ne-title",
        "link": {
          "selector": "a",
          "attr": "href"
        },
        "date": "span.ne-date"
      },
      "viewer": {
        "fetchMethod": "api",
        "decryptApi": {
          "endpoint": "/api/novel-content",
          "cookieName": "nv",
          "clientHeader": "shadow-v2"
        },
        "remove": [".a28415453-br", "[aria-label='배너 광고']"],
        "novelContent": "article.novel-viewer",
        "imageContainer": "article.novel-viewer",
        "imageItem": "p",
        "lazyAttrOptions": []
      }
    }
  ]
}
