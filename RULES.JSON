[
  {
    "id": "sbxh_webtoon",
    "name": "SBXH 웹툰",
    "urlPattern": ".*sbxh[0-9]*\\..*/webtoon/.*",
    "category": "Webtoon",
    "idExtraction": {
      "source": "url",
      "regex": "\\/webtoon\\/([0-9]+)"
    },
    "meta": {
      "title": "h1.hero-v2-title",
      "author": "div.hero-v2-author",
      "thumb": {
        "selector": "meta[property=\"og:image\"]",
        "attr": "content"
      },
      "status": "span.pill-status",
      "tags": "div.hero-v2-tags"
    },
    "list": {
      "container": "ul.ep-list-v2",
      "item": "li.ep-row-v2",
      "num": "span.ep-row-v2-no",
      "title": ".ep-row-v2-title strong",
      "link": {
        "selector": "a.ep-row-v2-link",
        "attr": "href"
      },
      "date": "span.ep-row-v2-date"
    },
    "viewer": {
      "fetchMethod": "iframe",
      "remove": [
        ".a28415453-br",
        "[aria-label='배너']"
      ],
      "imageContainer": "div.vw-imgs",
      "imageItem": "img",
      "lazyAttrOptions": [
        "src",
        "data-src",
        "data-lazy"
      ]
    }
  },
  {
    "id": "sbxh_manhwa",
    "name": "SBXH 만화",
    "urlPattern": ".*sbxh[0-9]*\\..*/manhwa/.*",
    "category": "Manga",
    "idExtraction": {
      "source": "url",
      "regex": "\\/manhwa\\/([0-9]+)"
    },
    "meta": {
      "title": "h1.hero-v2-title",
      "author": "div.hero-v2-author",
      "thumb": {
        "selector": "meta[property=\"og:image\"]",
        "attr": "content"
      },
      "status": "span.pill-status",
      "tags": "div.hero-v2-tags"
    },
    "list": {
      "container": "ul.ep-list-v2",
      "item": "li.ep-row-v2",
      "num": "span.ep-row-v2-no",
      "title": ".ep-row-v2-title strong",
      "link": {
        "selector": "a.ep-row-v2-link",
        "attr": "href"
      },
      "date": "span.ep-row-v2-date"
    },
    "viewer": {
      "fetchMethod": "iframe",
      "remove": [
        ".a28415453-br",
        "[aria-label='배너']"
      ],
      "imageContainer": "div.vw-imgs",
      "imageItem": "img",
      "lazyAttrOptions": [
        "src",
        "data-src",
        "data-lazy"
      ]
    }
  },
  {
    "id": "sbxh_novel",
    "name": "SBXH 소설 (shadow-v3)",
    "urlPattern": ".*sbxh[0-9]*\\..*/novel/.*",
    "category": "Novel",
    "idExtraction": {
      "source": "url",
      "regex": "\\/novel\\/([0-9]+)"
    },
    "meta": {
      "title": "div.nd-info h1",
      "author": "div.nd-meta span:first-child",
      "thumb": {
        "selector": "div.nd-thumb img",
        "attr": "src"
      },
      "status": "span.nv-badge",
      "tags": "div.hero-v2-tags"
    },
    "list": {
      "container": "ul.novel-eps",
      "item": "li.novel-ep-row",
      "num": "span.ne-num",
      "title": "span.ne-title",
      "link": {
        "selector": "a.novel-ep-link",
        "attr": "href"
      },
      "date": "span.ne-date"
    },
    "viewer": {
      "fetchMethod": "api",
      "decryptApi": {
        "endpoint": "/api/novel-content",
        "cookieName": "nv",
        "clientHeader": "shadow-v3"
      },
      "seriesTitle": "div.crumb a:last-of-type",
      "episodeTitle": "h1.ne-h1",
      "episodeNum": "div.crumb strong:last-child",
      "novelContent": "article.novel-viewer"
    }
  }
]
